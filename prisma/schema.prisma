generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  conversations Conversation[]
  checkoutRecords CheckoutRecord[]
  recipientMemories RecipientMemory[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model GuestSession {
  id            String   @id @default(cuid())
  token         String   @unique
  expiresAt     DateTime
  migratedToUserId String?
  migratedAt    DateTime?
  conversations Conversation[]
  checkoutRecords CheckoutRecord[]
  recipientMemories RecipientMemory[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Conversation {
  id             String   @id @default(cuid())
  title          String   @default("New gift chat")
  language       String   @default("english")
  userId         String?
  guestSessionId String?
  cartSnapshot   Json?
  lastProducts   Json?
  lastDelivery   Json?
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestSession   GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  messages       Message[]
  checkoutRecords CheckoutRecord[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, updatedAt])
  @@index([guestSessionId, updatedAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  metadata       Json?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
}

model CheckoutRecord {
  id             String   @id @default(cuid())
  conversationId String?
  userId         String?
  guestSessionId String?
  orderRef       String?
  checkoutUrl    String   @db.Text
  summary        Json
  expiresAt      DateTime?
  rawResult      Json?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestSession   GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([conversationId])
  @@index([userId, createdAt])
  @@index([guestSessionId, createdAt])
}

model RecipientMemory {
  id             String   @id @default(cuid())
  userId         String?
  guestSessionId String?
  recipientKey   String
  displayName    String
  occasions      String[] @default([])
  preferredCategories String[] @default([])
  deliveryCities String[] @default([])
  minBudget      Int?
  maxBudget      Int?
  lastProducts   Json?
  notes          String[] @default([])
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestSession   GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, recipientKey])
  @@unique([guestSessionId, recipientKey])
  @@index([userId, updatedAt])
  @@index([guestSessionId, updatedAt])
}
